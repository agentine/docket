{
  "name": "@agentine/docket",
  "version": "0.1.0",
  "description": "Drop-in replacement for node-schedule — zero-dependency cron and job scheduler for Node.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentine/docket.git"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    },
    "./compat/node-schedule": {
      "import": "./dist/esm/compat/node-schedule.js",
      "require": "./dist/cjs/compat/node-schedule.js",
      "types": "./dist/esm/compat/node-schedule.d.ts"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
